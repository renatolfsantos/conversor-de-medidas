#:kivy 2.3.1

<MainWindow>:
    name: 'main'
    BoxLayout:
        orientation: "horizontal"

        BoxLayout:
            size_hint: 0.3, 1
            canvas.before:
                Color:
                    rgba: 1, 0, 0, 1 
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "Seção 1"

        BoxLayout:
            canvas.before:
                Color:
                    rgba: 0, 0, 1, 1 
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "Seção 2"