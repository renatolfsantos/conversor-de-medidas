#:kivy 2.3.1
#:import Window kivy.core.window.Window

<WelcomeWindow>:
    name: "welcome"
    BoxLayout:
        orientation: "vertical"
        padding: Window.width * 0.15
        spacing: Window.height * 0.02

        canvas.before:
            Color:
                rgba: 0.1, 0.1, 0.1, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: "Conversor de Medidas"
            font_size: (Window.width + Window.height) * 0.03
            bold: True
            color: 0.9, 0.9, 0.9, 1

        Label:
            text: "Escolha o tipo de conversão"
            font_size: (Window.width + Window.height) * 0.015
            color: 0.5, 0.5, 0.5, 1

        GridLayout:
            id: grid_buttons
            spacing: Window.width * 0.02
            size_hint_y: None

            cols: 4

            Button:
                text: "Comprimento"
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.2, 0.6, 0.86, 1
                font_size: (Window.width + Window.height) * 0.013

                canvas.before:
                    Color:
                        rgba: 0.15, 0.15, 0.15, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]

                    Color:
                        rgba: 0.2, 0.6, 0.86, 0.6
                    Line:
                        width: 1.2
                        rounded_rectangle: (*self.pos, *self.size, 15)
                on_release:
                    root.manager.transition.direction = "left"
                    root.manager.current = "main"

            Button:
                text: "Massa"
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.2, 0.7, 0.4, 1
                font_size: (Window.width + Window.height) * 0.013

                canvas.before:
                    Color:
                        rgba: 0.15, 0.15, 0.15, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]

                    Color:
                        rgba: 0.2, 0.7, 0.4, 0.6
                    Line:
                        width: 1.2
                        rounded_rectangle: (*self.pos, *self.size, 15)
                on_release:
                    root.manager.transition.direction = "left"
                    root.manager.current = "main"

            Button:
                text: "Temperatura"
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.9, 0.5, 0.2, 1
                font_size: (Window.width + Window.height) * 0.013

                canvas.before:
                    Color:
                        rgba: 0.15, 0.15, 0.15, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]

                    Color:
                        rgba: 0.9, 0.5, 0.2, 0.6
                    Line:
                        width: 1.2
                        rounded_rectangle: (*self.pos, *self.size, 15)
                on_release:
                    root.manager.transition.direction = "left"
                    root.manager.current = "main"

            Button:
                text: "Volume"
                background_normal: ""
                background_color: 0, 0, 0, 0
                color: 0.6, 0.3, 0.8, 1
                font_size: (Window.width + Window.height) * 0.013

                canvas.before:
                    Color:
                        rgba: 0.15, 0.15, 0.15, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]

                    Color:
                        rgba: 0.6, 0.3, 0.8, 0.6
                    Line:
                        width: 1.2
                        rounded_rectangle: (*self.pos, *self.size, 15)
                on_release:
                    root.manager.transition.direction = "left"
                    root.manager.current = "main"